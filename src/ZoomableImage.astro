---
import { X, ZoomIn } from 'lucide-astro';
import type { ImageMetadata } from 'astro';
import type { HTMLAttributes } from 'astro/types';
type Props = Omit<HTMLAttributes<'img'>, 'src'> & { className?: string; src?: string | ImageMetadata };
const { class: classAttr, className, alt = '', src, width, height, ...imageProps } = Astro.props;
const image = src && typeof src === 'object' && 'src' in src ? src : undefined;
const resolvedSrc = typeof src === 'string' ? src : image?.src;
---
{resolvedSrc ? <span class="navfolio-zoomable" data-navfolio-zoomable><img {...imageProps} src={resolvedSrc} alt={alt} width={width ?? image?.width} height={height ?? image?.height} class={[classAttr, className].filter(Boolean).join(' ')} /><span aria-hidden="true"><ZoomIn size={20} /></span></span> : null}
<dialog class="navfolio-zoom-dialog" data-navfolio-zoom-dialog><button type="button" aria-label="Close image preview" data-close><X size={20} /></button><img alt="" data-image /></dialog>
<script>
  const init = () => {
    const dialog = document.querySelector<HTMLDialogElement>('[data-navfolio-zoom-dialog]'); if (!dialog || dialog.dataset.ready) return; dialog.dataset.ready = 'true'; const image = dialog.querySelector<HTMLImageElement>('[data-image]');
    document.querySelectorAll<HTMLElement>('[data-navfolio-zoomable]').forEach((item) => item.addEventListener('click', () => { const source = item.querySelector('img'); if (source && image) { image.src = source.currentSrc || source.src; image.alt = source.alt; dialog.showModal(); } }));
    dialog.querySelector('[data-close]')?.addEventListener('click', () => dialog.close()); dialog.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });
  }; document.addEventListener('astro:page-load', init); if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init, { once: true }); else init();
</script>
<style>
  :global(.navfolio-zoomable) { position: relative; display: block; width: fit-content; max-width: 100%; margin: 30px auto; overflow: hidden; border: 1px solid var(--paper-line); border-radius: 8px; cursor: zoom-in; } :global(.navfolio-zoomable img) { display: block; max-width: 100%; height: auto; } :global(.navfolio-zoomable > span) { position: absolute; inset: 0; display: grid; place-items: center; background: color-mix(in srgb, var(--paper-ink) 24%, transparent); color: var(--paper-surface); opacity: 0; transition: opacity 160ms ease; } :global(.navfolio-zoomable:hover > span) { opacity: 1; } :global(.navfolio-zoom-dialog) { width: 100%; max-width: none; height: 100%; max-height: none; padding: 28px; border: 0; background: color-mix(in srgb, var(--paper-ink) 74%, transparent); } :global(.navfolio-zoom-dialog[open]) { display: grid; place-items: center; } :global(.navfolio-zoom-dialog img) { max-width: min(100%, 1180px); max-height: 86vh; object-fit: contain; } :global(.navfolio-zoom-dialog button) { position: fixed; top: 18px; right: 18px; display: grid; width: 40px; height: 40px; place-items: center; border: 1px solid var(--paper-line); border-radius: 999px; background: var(--paper-surface); color: var(--paper-ink); cursor: pointer; }
</style>

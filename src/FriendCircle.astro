---
import { RefreshCw, Rss } from 'lucide-astro';
import {
  crawlFriendPosts,
  parseFriendPosts,
  resolveFriendLinkItems,
  type FriendDataSource,
  type FriendLinkItem,
  type FriendPost,
} from './lib/friend-data';

interface Props {
  items?: FriendLinkItem[];
  src?: string;
  source?: FriendDataSource;
  posts?: FriendPost[];
  feedSrc?: string;
  limit?: number;
  title?: string;
  refreshLabel?: string;
}

const { posts, feedSrc, limit = 10, title = 'Friend circle', refreshLabel = 'Refresh posts', ...dataSource } = Astro.props;
const friends = await resolveFriendLinkItems(dataSource);
const loadPosts = async (): Promise<FriendPost[]> => {
  if (posts) return posts;
  if (feedSrc?.trim()) {
    try {
      const response = await fetch(feedSrc.trim());
      if (!response.ok) throw new Error(`${response.status} ${response.statusText}`);
      return parseFriendPosts(JSON.parse(await response.text()));
    } catch (error) {
      console.error(`Unable to load friend circle data from ${feedSrc}:`, error);
      return [];
    }
  }
  return crawlFriendPosts(friends);
};
const allPosts: FriendPost[] = (await loadPosts()).slice(0, 120);
const dateValue = (date?: string) => {
  const parsed = date ? new Date(date) : null;
  return parsed && !Number.isNaN(parsed.valueOf()) ? parsed.toISOString().slice(0, 10) : '';
};
const initialPosts = allPosts.slice(0, limit).map((post) => ({ ...post, date: dateValue(post.date) }));
const activeFriends = new Set(allPosts.map((post) => post.authorUrl || post.author)).size;
---

<section class="friend-circle" data-friend-circle data-limit={limit}>
  <header class="friend-circle__header">
    <div>
      <p class="friend-circle__eyebrow"><Rss size={14} strokeWidth={1.8} aria-hidden="true" /> {title}</p>
      <p class="friend-circle__stats">{friends.length} friends <span aria-hidden="true">/</span> {activeFriends} active <span aria-hidden="true">/</span> {allPosts.length} posts</p>
    </div>
    <button class="friend-circle__refresh" type="button" aria-label={refreshLabel} title={refreshLabel} data-friend-circle-refresh>
      <RefreshCw size={17} strokeWidth={1.8} aria-hidden="true" />
    </button>
  </header>
  <div class="friend-circle__posts" data-friend-circle-posts></div>
  <script is:inline type="application/json" data-friend-circle-data set:html={JSON.stringify({ posts: allPosts.map((post) => ({ ...post, date: dateValue(post.date) })), initialPosts })} />
</section>

<script>
  type Post = { title: string; url: string; date?: string; tags?: string[]; author: string; authorUrl?: string; avatar?: string | null };
  const escape = (value: string) => value.replace(/[&<>"']/g, (character) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' })[character] ?? character);
  const shuffle = <T,>(items: T[]) => {
    const result = [...items];
    for (let index = result.length - 1; index > 0; index -= 1) {
      const target = Math.floor(Math.random() * (index + 1));
      [result[index], result[target]] = [result[target], result[index]];
    }
    return result;
  };
  const render = (root: HTMLElement, posts: Post[]) => {
    const target = root.querySelector<HTMLElement>('[data-friend-circle-posts]');
    if (!target) return;
    target.innerHTML = posts.map((post) => {
      const avatar = post.avatar ? `<img src="${escape(post.avatar)}" alt="" loading="lazy" decoding="async">` : `<span>${escape((post.author[0] || '?').toUpperCase())}</span>`;
      const tags = (post.tags ?? []).slice(0, 3).map((tag) => `<span>${escape(tag)}</span>`).join('');
      return `<a class="friend-circle__post" href="${escape(post.url)}" target="_blank" rel="noopener noreferrer"><span class="friend-circle__author-avatar">${avatar}</span><span class="friend-circle__author">${escape(post.author)}</span><strong class="friend-circle__post-title">${escape(post.title)}</strong><span class="friend-circle__post-meta">${tags ? `<span class="friend-circle__tags">${tags}</span>` : ''}${post.date ? `<time>${escape(post.date)}</time>` : ''}</span></a>`;
    }).join('');
  };
  const init = () => document.querySelectorAll<HTMLElement>('[data-friend-circle]').forEach((root) => {
    if (root.dataset.initialized) return;
    root.dataset.initialized = 'true';
    const data = root.querySelector<HTMLScriptElement>('[data-friend-circle-data]');
    if (!data?.textContent) return;
    const { posts, initialPosts } = JSON.parse(data.textContent) as { posts: Post[]; initialPosts: Post[] };
    const limit = Number(root.dataset.limit) || 10;
    render(root, initialPosts);
    root.querySelector<HTMLButtonElement>('[data-friend-circle-refresh]')?.addEventListener('click', (event) => {
      const button = event.currentTarget as HTMLButtonElement;
      button.classList.add('is-refreshing');
      render(root, shuffle(posts).slice(0, limit));
      window.setTimeout(() => button.classList.remove('is-refreshing'), 260);
    });
  });
  document.addEventListener('astro:page-load', init);
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init, { once: true }); else init();
</script>

<style>
  .friend-circle { margin: 34px 0; border-top: 1px solid var(--paper-line); border-bottom: 1px solid var(--paper-line); }
  .friend-circle__header { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 15px 0; }
  .friend-circle__eyebrow { display: flex; align-items: center; gap: 7px; margin: 0; color: var(--paper-ink); font-family: var(--font-meta); font-size: .86rem; font-weight: 700; }
  .friend-circle__eyebrow svg { color: var(--paper-accent); }
  .friend-circle__stats { margin: 4px 0 0; color: var(--paper-ink-faint); font-family: var(--font-meta); font-size: .72rem; }
  .friend-circle__stats span { margin: 0 5px; color: var(--paper-line-strong); }
  .friend-circle__refresh { display: grid; width: 32px; height: 32px; flex: 0 0 auto; place-items: center; border: 1px solid var(--paper-line); border-radius: 8px; background: transparent; color: var(--paper-ink-soft); cursor: pointer; transition: color 160ms ease, background 160ms ease, border-color 160ms ease; }
  .friend-circle__refresh:hover { border-color: var(--paper-line-strong); background: var(--paper-control-hover); color: var(--paper-ink); }
  .friend-circle__refresh.is-refreshing svg { animation: friend-circle-spin 260ms ease; }
  .friend-circle__posts { border-top: 1px solid var(--paper-line); }
  .friend-circle__post { display: grid; grid-template-columns: 28px max-content minmax(0, 1fr) auto; align-items: center; gap: 9px; min-height: 48px; border-bottom: 1px solid var(--paper-line); color: inherit; text-decoration: none; }
  .friend-circle__post:last-child { border-bottom: 0; }
  .friend-circle__post:hover .friend-circle__post-title { text-decoration: underline; text-decoration-color: color-mix(in srgb, var(--paper-accent) 56%, transparent); text-underline-offset: 4px; }
  .friend-circle__author-avatar { display: grid; width: 28px; height: 28px; place-items: center; overflow: hidden; border: 1px solid var(--paper-line); border-radius: 999px; background: var(--paper-surface-muted); font-size: .7rem; font-weight: 700; }
  .friend-circle__author-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .friend-circle__author { max-width: 9rem; overflow: hidden; color: var(--paper-ink-soft); font-family: var(--font-meta); font-size: .76rem; text-overflow: ellipsis; white-space: nowrap; }
  .friend-circle__post-title { min-width: 0; overflow: hidden; font-size: .88rem; font-weight: 600; line-height: 1.35; text-overflow: ellipsis; white-space: nowrap; }
  .friend-circle__post-meta { display: flex; align-items: center; justify-content: flex-end; gap: 8px; min-width: 0; color: var(--paper-ink-faint); font-family: var(--font-meta); font-size: .7rem; white-space: nowrap; }
  .friend-circle__tags { display: flex; gap: 4px; max-width: 14rem; overflow: hidden; }
  .friend-circle__tags span { overflow: hidden; color: color-mix(in srgb, var(--paper-accent) 72%, var(--paper-ink-soft)); text-overflow: ellipsis; white-space: nowrap; }
  .friend-circle__tags span::before { content: '#'; }
  @keyframes friend-circle-spin { to { transform: rotate(180deg); } }
  @media (max-width: 700px) { .friend-circle__post { grid-template-columns: 28px minmax(0, 1fr) auto; gap: 8px; padding: 7px 0; } .friend-circle__author { display: none; } .friend-circle__tags { display: none; } }
  @media (max-width: 440px) { .friend-circle__post-meta time { font-size: .65rem; } }
  @media (prefers-reduced-motion: reduce) { .friend-circle__refresh { transition: none; } .friend-circle__refresh.is-refreshing svg { animation: none; } }
</style>

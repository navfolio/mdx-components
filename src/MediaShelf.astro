---
import type { ImageMetadata } from 'astro';

export type MediaShelfItem = {
  title: string;
  creator: string;
  type: 'book' | 'film' | 'series' | 'album' | 'podcast';
  cover?: string | ImageMetadata;
  rating?: number;
  href?: string;
  note?: string;
};

interface Props {
  items: MediaShelfItem[];
  variant?: 'shelf' | 'inline';
  columns?: 2 | 3 | 4 | 5;
  class?: string;
}

const { items, variant = 'shelf', columns = 4, class: className } = Astro.props;
const coverSrc = (cover: MediaShelfItem['cover']) => (typeof cover === 'string' ? cover : cover?.src);
const ratingLabel = (rating: number | undefined) =>
  rating ? ` · ${'★'.repeat(Math.max(1, Math.min(5, Math.round(rating))))}` : '';
---

<section
  class:list={['navfolio-media-shelf', `navfolio-media-shelf--${variant}`, className]}
  style={`--media-shelf-columns: ${columns};`}
  aria-label="Media shelf"
>
  {
    items.map((item) => {
      const content = <>
        <figure class="navfolio-media-shelf__cover" data-media-type={item.type}>
          {coverSrc(item.cover) ? (
            <img src={coverSrc(item.cover)} alt={`${item.title} cover`} loading="lazy" decoding="async" />
          ) : (
            <span aria-hidden="true">{item.type}</span>
          )}
        </figure>
        <div class="navfolio-media-shelf__content">
          <strong>{item.title}</strong>
          <span class="navfolio-media-shelf__meta">{item.creator}{ratingLabel(item.rating)}</span>
          {item.note ? <p>{item.note}</p> : null}
        </div>
      </>;

      return item.href ? (
        <a class="navfolio-media-shelf__item" href={item.href} target="_blank" rel="noreferrer">
          {content}
        </a>
      ) : (
        <article class="navfolio-media-shelf__item">{content}</article>
      );
    })
  }
</section>

<style>
  .navfolio-media-shelf { container-type: inline-size; width:100%; margin:24px 0 28px; color:var(--paper-ink); }
  .navfolio-media-shelf__item { min-width:0; color:inherit; text-decoration:none; }
  .navfolio-media-shelf__cover { display:grid; margin:0; overflow:hidden; place-items:center; border:1px solid var(--paper-line); border-radius:7px; background:var(--paper-surface-muted); color:var(--paper-ink-faint); }
  .navfolio-media-shelf__cover img { width:100%; height:100%; object-fit:cover; }
  .navfolio-media-shelf__cover span { font-family:var(--font-meta); font-size:.64rem; letter-spacing:.08em; text-transform:uppercase; }
  .navfolio-media-shelf__content { min-width:0; }
  .navfolio-media-shelf__content strong, .navfolio-media-shelf__meta { display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .navfolio-media-shelf__content strong { color:var(--paper-ink); font-family:var(--font-ui-label); font-size:.87rem; font-weight:500; line-height:1.4; }
  .navfolio-media-shelf__meta { margin-top:3px; color:var(--paper-ink-faint); font-family:var(--font-meta); font-size:.64rem; line-height:1.5; }
  .navfolio-media-shelf__content p { margin:8px 0 0; color:var(--paper-ink-soft); font-family:var(--font-serif-cn); font-size:.9rem; line-height:1.75; }
  .navfolio-media-shelf__item:hover strong { color:var(--paper-accent); }

  .navfolio-media-shelf--shelf { display:grid; grid-template-columns:repeat(var(--media-shelf-columns), minmax(0, 1fr)); gap:clamp(14px, 2vw, 22px) 14px; }
  .navfolio-media-shelf--shelf .navfolio-media-shelf__item { display:grid; gap:10px; justify-items:center; width:100%; text-align:center; }
  .navfolio-media-shelf--shelf .navfolio-media-shelf__cover { width:min(100%, 176px); aspect-ratio:2 / 3; }
  .navfolio-media-shelf--shelf .navfolio-media-shelf__cover[data-media-type='film'], .navfolio-media-shelf--shelf .navfolio-media-shelf__cover[data-media-type='series'] { aspect-ratio:16 / 10; }
  .navfolio-media-shelf--shelf .navfolio-media-shelf__cover[data-media-type='album'], .navfolio-media-shelf--shelf .navfolio-media-shelf__cover[data-media-type='podcast'] { aspect-ratio:1; }
  .navfolio-media-shelf--shelf .navfolio-media-shelf__content { width:100%; }
  .navfolio-media-shelf--shelf .navfolio-media-shelf__content p { display:none; }

  .navfolio-media-shelf--inline { display:grid; gap:22px; }
  .navfolio-media-shelf--inline .navfolio-media-shelf__item { display:grid; grid-template-columns:clamp(92px, 18cqi, 142px) minmax(0, 1fr); gap:clamp(14px, 3cqi, 24px); align-items:start; }
  .navfolio-media-shelf--inline .navfolio-media-shelf__cover { aspect-ratio:2 / 3; }
  .navfolio-media-shelf--inline .navfolio-media-shelf__cover[data-media-type='film'], .navfolio-media-shelf--inline .navfolio-media-shelf__cover[data-media-type='series'] { aspect-ratio:16 / 10; }
  .navfolio-media-shelf--inline .navfolio-media-shelf__cover[data-media-type='album'], .navfolio-media-shelf--inline .navfolio-media-shelf__cover[data-media-type='podcast'] { aspect-ratio:1; }
  .navfolio-media-shelf--inline .navfolio-media-shelf__content { padding-top:2px; }
  .navfolio-media-shelf--inline .navfolio-media-shelf__content strong { font-size:1rem; white-space:normal; }

  @container (max-width: 620px) { .navfolio-media-shelf--shelf { grid-template-columns:repeat(min(3, var(--media-shelf-columns)), minmax(0, 1fr)); } }
  @container (max-width: 420px) { .navfolio-media-shelf--shelf { grid-template-columns:repeat(2, minmax(0, 1fr)); } .navfolio-media-shelf--inline .navfolio-media-shelf__item { grid-template-columns:88px minmax(0, 1fr); gap:14px; } }
  @media (max-width: 720px) { .navfolio-media-shelf--shelf { grid-template-columns:repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 430px) { .navfolio-media-shelf--shelf { grid-template-columns:repeat(2, minmax(0, 1fr)); } }
</style>
